# Reddit API (optional - get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=altdata-platform/1.0

# OpenSky Network (optional - free registration at https://opensky-network.org)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# TransMedics Aircraft ICAO24 codes (comma-separated hex codes)
# Look up at https://registry.faa.gov/AircraftInquiry/
# Search by Owner for "TransMedics", note N-numbers, convert to ICAO24 hex
TMDX_AIRCRAFT_ICAO24=

# Database (SQLite by default - no setup needed)
DATABASE_URL=sqlite:///./altdata.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Next.js - API URL used by the browser
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Logging
LOG_LEVEL=INFO
